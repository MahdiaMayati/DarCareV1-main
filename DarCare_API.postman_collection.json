{
  "info": {
    "_postman_id": "darcare-v1-api-collection",
    "name": "DarCare API",
    "description": "Postman collection generated from routes/api.php and module route files.\n\nBase URL: `{{base_url}}`\n\n- Most endpoints: `/api/v1/...`\n- Dashboard module (loaded via DashboardServiceProvider): `/api/admin/...` (no v1 prefix)\n\nRun **Login User** or **Login Provider** first; the token is saved automatically to `{{token}}` for Bearer auth on protected routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "id",
      "value": "1"
    },
    {
      "key": "providerId",
      "value": "1"
    },
    {
      "key": "requestId",
      "value": "1"
    },
    {
      "key": "addressId",
      "value": "1"
    },
    {
      "key": "categoryId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "app/Modules/Auth/routes/api.php",
      "item": [
        {
          "name": "Register User",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"phone\": \"+966500000001\",\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"address\": {\n    \"latitude\": 24.7136,\n    \"longitude\": 46.6753,\n    \"label\": \"home\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/v1/auth/register/user",
            "description": "POST auth/register/user"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const token = json?.data?.token || json?.data?.user?.token;",
                  "if (token) pm.collectionVariables.set('token', token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Provider",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Ahmed Provider", "type": "text" },
                { "key": "phone", "value": "+966500000002", "type": "text" },
                { "key": "email", "value": "provider@example.com", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" },
                { "key": "password_confirmation", "value": "password123", "type": "text" },
                { "key": "years_of_experience", "value": "5", "type": "text" },
                { "key": "bio", "value": "Experienced technician", "type": "text" },
                { "key": "profile_image", "type": "file", "src": [] },
                { "key": "category_ids[]", "value": "1", "type": "text" },
                { "key": "address[latitude]", "value": "24.7136", "type": "text" },
                { "key": "address[longitude]", "value": "46.6753", "type": "text" },
                { "key": "address[label]", "value": "work", "type": "text" }
              ]
            },
            "url": "{{base_url}}/api/v1/auth/register/provider",
            "description": "POST auth/register/provider (multipart/form-data)"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const token = json?.data?.token;",
                  "if (token) pm.collectionVariables.set('token', token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/v1/auth/login/user",
            "description": "POST auth/login/user"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const token = json?.data?.token;",
                  "if (token) pm.collectionVariables.set('token', token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Provider",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"provider@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/v1/auth/login/provider",
            "description": "POST auth/login/provider"
